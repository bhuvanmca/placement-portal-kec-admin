# Application Configuration
PORT=8080
ENV=production

# Database Configuration
# Format: postgres://username:password@localhost:5432/dbname?sslmode=disable
DB_URL=postgres://pi:your_password@localhost:5432/placement_db?sslmode=disable

# Security
JWT_SECRET=generate_a_secure_random_string_here

# Email Service (Gmail App Password)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Garage S3-Compatible Storage (Self-Hosted)
# For local development:
GARAGE_ENDPOINT=localhost:3900
GARAGE_PUBLIC_URL=http://localhost:3900
GARAGE_ACCESS_KEY=admin
GARAGE_SECRET_KEY=password123
GARAGE_BUCKET=placement-portal-bucket
GARAGE_REGION=ap-south-1
GARAGE_USE_SSL=false

# For production (Raspberry Pi):
# GARAGE_ENDPOINT=garage:3900
# GARAGE_PUBLIC_URL=http://172.20.10.2:3900

# BrandFetch API (Optional - for company logos)
BRANDFETCH_API_KEY=your_api_key_here
