{
    # Global options
    email kecdrives@kongu.edu
}

# API Gateway — Routes to Microservices
:80 {
    # ──────────────────────────────────────────────
    # 1. Auth Service (port 8081)
    # ──────────────────────────────────────────────
    handle /api/v1/auth/* {
        reverse_proxy auth-service:8081 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }

    # ──────────────────────────────────────────────
    # 2. Chat Service (port 8082)
    # ──────────────────────────────────────────────
    handle /api/chat/* {
        reverse_proxy chat-service:8081 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }
    handle /ws {
        reverse_proxy chat-service:8081 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }

    # ──────────────────────────────────────────────
    # 3. Drive Service (port 8083)
    # ──────────────────────────────────────────────
    handle /api/v1/drives* {
        reverse_proxy drive-service:8083 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }
    handle /api/v1/admin/drives* {
        reverse_proxy drive-service:8083 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }

    # ──────────────────────────────────────────────
    # 4. Student Service (port 8084)
    # ──────────────────────────────────────────────
    handle /api/v1/student/requests/* {
        reverse_proxy student-service:8084 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }
    handle /api/v1/student/documents/* {
        reverse_proxy student-service:8084 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }
    handle /api/v1/student/* {
        reverse_proxy student-service:8084 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }
    handle /api/v1/admin/students/*/documents/* {
        reverse_proxy student-service:8084
    }
    handle /api/v1/user/upload/profile-photo {
        reverse_proxy student-service:8084
    }
    handle /api/v1/user/fcm-token {
        reverse_proxy student-service:8084
    }
    handle /api/v1/chat/upload {
        reverse_proxy student-service:8084
    }

    # ──────────────────────────────────────────────
    # 5. Admin Service (port 8085)
    # ──────────────────────────────────────────────
    # Admin auth (public - forgot/reset password)
    handle /api/v1/admin/auth/* {
        reverse_proxy admin-service:8085 {
            lb_try_duration 5s
            fail_duration 30s
            unhealthy_status 502 503 504
        }
    }
    # Dashboard stats
    handle /api/v1/admin/dashboard/* {
        reverse_proxy admin-service:8085
    }
    # Config (public read)
    handle /api/v1/config/* {
        reverse_proxy admin-service:8085
    }
    # SPOCs (public read)
    handle /api/v1/spocs* {
        reverse_proxy admin-service:8085
    }
    # Brands
    handle /api/v1/brands/* {
        reverse_proxy admin-service:8085
    }
    # User account management
    handle /api/v1/user/account {
        reverse_proxy admin-service:8085
    }
    handle /api/v1/user/password {
        reverse_proxy admin-service:8085
    }
    # Settings (public)
    handle /api/v1/settings* {
        reverse_proxy admin-service:8085
    }
    # Admin student management
    handle /api/v1/admin/students* {
        reverse_proxy admin-service:8085
    }
    # Admin users block
    handle /api/v1/admin/users/* {
        reverse_proxy admin-service:8085
    }
    # Admin storage
    handle /api/v1/admin/storage/* {
        reverse_proxy admin-service:8085
    }
    # Admin system
    handle /api/v1/admin/system/* {
        reverse_proxy admin-service:8085
    }
    # Admin archive
    handle /api/v1/admin/archive/* {
        reverse_proxy admin-service:8085
    }
    # Admin drive requests and applications
    handle /api/v1/admin/applications/* {
        reverse_proxy admin-service:8085
    }
    handle /api/v1/admin/drive-requests* {
        reverse_proxy admin-service:8085
    }
    # Admin settings/fields, requests, broadcast, eligibility
    handle /api/v1/admin/settings* {
        reverse_proxy admin-service:8085
    }
    handle /api/v1/admin/requests* {
        reverse_proxy admin-service:8085
    }
    handle /api/v1/admin/broadcast/* {
        reverse_proxy admin-service:8085
    }
    handle /api/v1/admin/eligibility-templates* {
        reverse_proxy admin-service:8085
    }
    handle /api/v1/admin/spocs* {
        reverse_proxy admin-service:8085
    }
    # Super admin
    handle /api/v1/super-admin/* {
        reverse_proxy admin-service:8085
    }

    # ──────────────────────────────────────────────
    # 6. Analytics Service (port 8086)
    # ──────────────────────────────────────────────
    handle /api/v1/admin/analytics/* {
        reverse_proxy analytics-service:8086
    }

    # ──────────────────────────────────────────────
    # Monitoring Stack (Firewall Bypass)
    # ──────────────────────────────────────────────
    # Simplify matchers to catch both /path and /path/
    handle /prometheus* {
        reverse_proxy prometheus:9090
    }

    handle /grafana* {
        reverse_proxy grafana:3000
    }

    # Safety: Block legacy Swagger routes
    handle /swagger* {
        error "Not Found" 404
    }

    handle /pgadmin {
        redir * /pgadmin/
    }
    handle /pgadmin/* {
        reverse_proxy pgadmin:80 {
            header_up X-Script-Name /pgadmin
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /logs {
        redir * /logs/
    }
    handle /logs/* {
        reverse_proxy logs:8080
    }

    # ──────────────────────────────────────────────
    # Health Check (aggregated)
    # ──────────────────────────────────────────────
    handle /api/health {
        respond "Placement Portal Gateway OK" 200
    }

    # ──────────────────────────────────────────────
    # Garage Storage (Public Access)
    # ──────────────────────────────────────────────
    handle_path /storage/* {
        reverse_proxy garage:3900
    }

    # ──────────────────────────────────────────────
    # Static Assets
    # ──────────────────────────────────────────────
    handle /assets/* {
        root * /app/assets
        file_server
    }

    # Default handler
    handle /* {
        respond "Placement Portal API Gateway" 200
    }
}
